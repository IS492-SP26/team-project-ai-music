# -----------------------------------------------------------------------------
# Scanned from app/ and lib/ for explicit process.env usage
# -----------------------------------------------------------------------------

# Set automatically by Next.js — do not need to set locally for normal dev.
# NODE_ENV=development

# -----------------------------------------------------------------------------
# Recommended for production / AI (used by Vercel AI SDK & hosting)
# Not referenced directly in app/ or lib/ source, but required for live AI calls.
# -----------------------------------------------------------------------------

# Vercel AI Gateway (local tests / non-Vercel hosts). On Vercel, OIDC auth may apply instead.
# See: https://ai-sdk.dev/unauthenticated-ai-gateway
# AI_GATEWAY_API_KEY=

# If calling OpenAI-compatible APIs directly (optional; depends on deployment)
# OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Optional: client-side feature flags (none required today)
# Prefix public vars with NEXT_PUBLIC_ to expose to the browser.
# -----------------------------------------------------------------------------

# NEXT_PUBLIC_DEBUG_PREVIEW=0

# -----------------------------------------------------------------------------
# Optional: observability (documented in app/docs/GOVERNANCE.md; wire in your stack)
# -----------------------------------------------------------------------------

# SENTRY_DSN=
# DATABASE_URL=
