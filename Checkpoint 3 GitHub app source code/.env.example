# -----------------------------------------------------------------------------
# Copy to .env.local and fill in values. Never commit real secrets.
# -----------------------------------------------------------------------------

# Set by Next.js in dev/production — you normally do not set this manually.
# NODE_ENV=development

# -----------------------------------------------------------------------------
# AI (Vercel AI SDK / AI Gateway)
# https://ai-sdk.dev/unauthenticated-ai-gateway
# AI_GATEWAY_API_KEY=

# Optional direct provider (depends on your AI Gateway / provider setup)
# OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Optional: client-side flags (prefix with NEXT_PUBLIC_ to expose to the browser)
# -----------------------------------------------------------------------------

# NEXT_PUBLIC_DEBUG_PREVIEW=0

# -----------------------------------------------------------------------------
# Observability (optional — see docs/telemetry.md)
# -----------------------------------------------------------------------------

# SENTRY_DSN=

# -----------------------------------------------------------------------------
# Supabase — backend database for generation logs
# Dashboard: Project Settings → API (URL, anon key, service_role)
# SQL: docs/supabase-generations.sql, docs/supabase-rls-and-grants.sql
# -----------------------------------------------------------------------------

# Public (safe to expose in browser bundles; protect data with RLS)
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: used by lib/supabaseServer.ts for inserts from POST /api/generate.
# Bypasses RLS — do NOT prefix with NEXT_PUBLIC_, do NOT commit to GitHub.
# SUPABASE_SERVICE_ROLE_KEY=
